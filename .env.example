# Variables de entorno para Vercel (Settings → Environment Variables)

# Acceso al panel /admin
ADMIN_EMAIL=ohmios@admin.com
ADMIN_PASSWORD=9999

# Secreto para tokens de sesión (genera una cadena aleatoria larga)
ADMIN_SECRET=ohmios-cms-secret-cambiar-en-produccion

# Token de GitHub con permiso de escritura en el repo
# Crear en: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# Permisos: Contents Read and Write en iwaterhd-beep/ohmios
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Opcional (valores por defecto)
GITHUB_OWNER=iwaterhd-beep
GITHUB_REPO=ohmios
GITHUB_BRANCH=main
